использовать Комплексные числа

алг
нач
    компл a, b, c

    a := 1.0 + 2.0*i
    b := 3.0 - 4.0*i

    c := a + b
    вывод "a+b: ", Re(c), " ", Im(c), нс

    c := a - b
    вывод "a-b: ", Re(c), " ", Im(c), нс

    c := a * b
    вывод "a*b: ", Re(c), " ", Im(c), нс

    c := a / b
    вывод "a/b: ", Re(c), " ", Im(c), нс

    вывод "a=a: ", a = a, " a<>b: ", a <> b, нс
кон
