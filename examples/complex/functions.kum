использовать Комплексные числа

алг компл make_complex(вещ re, вещ im)
нач
    знач := re + im*i
кон

алг компл rotate90(компл z)
нач
    знач := z * i
кон

алг add_in_place(арг рез компл z, компл delta)
нач
    z := z + delta
кон

алг
нач
    компл z

    z := make_complex(2.0, 1.0)
    вывод "z: ", Re(z), " ", Im(z), нс

    z := rotate90(z)
    вывод "rotated: ", Re(z), " ", Im(z), нс

    add_in_place(z, 3.0 + 0.5*i)
    вывод "updated: ", Re(z), " ", Im(z), нс
кон
