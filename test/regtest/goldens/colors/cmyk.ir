    load tmp(269,i64) = local(3,i64) 
    arg tmp(269,i64) 
    arg imm(0,i64) 
    call output_int64 
    arg imm(4,ptr to i8) 
    call output_string 
    jmp label(1) 
  }
  block {
    label: label(1)
    ret 
  }
}
