                            (var $$p = (* $$vf (- 1 $$sf)))
                            (var $$q = (* $$vf (- 1 (* $$f $$sf))))
                            (var $$t = (* $$vf (- 1 (* (- 1 $$f) $$sf))))
                            (: (cast
                                (| (| (| (<< (& 255 255) 24)
                                      (<< (& (cast
                                            (+ (* (if
                                                  (== $$i 0)
                                                  $$vf
                                                  (if
                                                    (== $$i 1)
                                                    $$q
                                                    (if (== $$i 2) $$p (if (== $$i 3) $$p (if (== $$i 4) $$t $$vf)))))
                                                255)
                                              0.5)
                                            i64)
                                          255)
                                        16))
                                    (<< (& (cast
