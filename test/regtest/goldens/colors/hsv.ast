                                            (== $$i 0)
                                            $$p
                                            (if
                                              (== $$i 1)
                                              $$p
                                              (if (== $$i 2) $$t (if (== $$i 3) $$vf (if (== $$i 4) $$vf $$q)))))
                                          255)
                                        0.5)
                                      i64)
                                    255))
                                <named цвет>)
                              <named цвет>))
                          <named цвет>))
                      <named цвет>))
                  <named цвет>))
              <named цвет>))
          <named цвет>))
      (block
        (var $$color_decompose_rgb_0 i64)
        (= $$color_decompose_rgb_0 (cast (: c <named цвет>) i64))
        (= r (& (>> $$color_decompose_rgb_0 16) 255))
        (= g (& (>> $$color_decompose_rgb_0 8) 255))
        (= b (& $$color_decompose_rgb_0 255)))
      (block
