(block
  (fun f () -> string
    (block
      (var $$return string)
      (var s string)
      (= s "s12345")
      (call g s)
      (= $$return s)))
  (fun g ((var s <ref string>))
    (block
      (var a char)
      (= a (call str_symbol_at s 1))
      (= s (call str_concat s (call str_from_unicode a))))))