      (= h2 (* h h))
      (var lam f64)
      (var dt f64)
      (var T f64)
      (= lam 0.5)
      (= dt (* lam h2))
      (= T 0.1)
      (var nt i64)
      (= nt (call int (/ T dt)))
      (cond (< nt 1) (block (= nt 1)))
      (seq
        (var $$u_lbound3 i64)
        (var $$u_dimsize3 i64)
        (var $$u_mulacc3 i64)
        (= $$u_lbound3 0)
        (= $$u_dimsize3 (+ (- (- Nz 1) 0) 1))
        (= $$u_mulacc3 (* 1 $$u_dimsize3))
        (var $$u_lbound2 i64)
        (var $$u_dimsize2 i64)
        (var $$u_mulacc2 i64)
        (= $$u_lbound2 0)
        (= $$u_dimsize2 (+ (- (- Ny 1) 0) 1))
        (= $$u_mulacc2 (* (* 1 $$u_dimsize3) $$u_dimsize2))
        (var $$u_lbound1 i64)
        (var $$u_dimsize1 i64)
        (var $$u_mulacc1 i64)
        (= $$u_lbound1 0)
        (= $$u_dimsize1 (+ (- (- Nx 1) 0) 1))
        (= $$u_mulacc1 (* (* (* 1 $$u_dimsize3) $$u_dimsize2) $$u_dimsize1))
        (var $$u_lbound0 i64)
        (var $$u_dimsize0 i64)
        (var $$u_mulacc0 i64)
        (= $$u_lbound0 0)
        (= $$u_dimsize0 (+ (- nt 0) 1))
        (= $$u_mulacc0 (* (* (* (* 1 $$u_dimsize3) $$u_dimsize2) $$u_dimsize1) $$u_dimsize0))
        (var u <array f64 4>))
      (var i i64)
      (var j i64)
