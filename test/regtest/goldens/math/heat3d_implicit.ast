            (block
              (var $$to i64)
              (var $$step i64)
              (var $$next i64)
              (= j 0)
              (= $$step 1)
              (= $$next j)
              (= $$to (- Ny 1))
              (loop
                (>= (* (- $$to $$next) $$step) 0)
                (= j $$next)
