(block
  (fun <main> void () ()
    (block
      (var Nx i64)
      (var Ny i64)
      (var Nz i64)
      (= Nx 8)
      (= Ny 8)
      (= Nz 8)
      (var pi f64)
      (= pi 3.14159)
      (var h f64)
      (= h (/ 1 (cast (- Nx 1) f64)))
      (var h2 f64)
      (= h2 (* h h))
      (var dt f64)
      (var T f64)
      (var alpha f64)
      (= alpha 0.1)
      (= dt (* alpha h2))
      (= T 0.05)
      (seq
        (var $$u_lbound2 i64)
        (var $$u_dimsize2 i64)
        (var $$u_mulacc2 i64)
        (= $$u_lbound2 0)
        (= $$u_dimsize2 (+ (- (- Nz 1) 0) 1))
        (= $$u_mulacc2 (* 1 $$u_dimsize2))
        (var $$u_lbound1 i64)
        (var $$u_dimsize1 i64)
        (var $$u_mulacc1 i64)
        (= $$u_lbound1 0)
        (= $$u_dimsize1 (+ (- (- Ny 1) 0) 1))
        (= $$u_mulacc1 (* (* 1 $$u_dimsize2) $$u_dimsize1))
        (var $$u_lbound0 i64)
        (var $$u_dimsize0 i64)
        (var $$u_mulacc0 i64)
        (= $$u_lbound0 0)
        (= $$u_dimsize0 (+ (- (- Nx 1) 0) 1))
        (= $$u_mulacc0 (* (* (* 1 $$u_dimsize2) $$u_dimsize1) $$u_dimsize0))
        (var u <array f64 3>))
      (seq
        (var $$un_lbound2 i64)
        (var $$un_dimsize2 i64)
        (var $$un_mulacc2 i64)
        (= $$un_lbound2 0)
        (= $$un_dimsize2 (+ (- (- Nz 1) 0) 1))
        (= $$un_mulacc2 (* 1 $$un_dimsize2))
        (var $$un_lbound1 i64)
        (var $$un_dimsize1 i64)
        (var $$un_mulacc1 i64)
        (= $$un_lbound1 0)
        (= $$un_dimsize1 (+ (- (- Ny 1) 0) 1))
        (= $$un_mulacc1 (* (* 1 $$un_dimsize2) $$un_dimsize1))
        (var $$un_lbound0 i64)
        (var $$un_dimsize0 i64)
        (var $$un_mulacc0 i64)
        (= $$un_lbound0 0)
        (= $$un_dimsize0 (+ (- (- Nx 1) 0) 1))
        (= $$un_mulacc0 (* (* (* 1 $$un_dimsize2) $$un_dimsize1) $$un_dimsize0))
        (var un <array f64 3>))
      (var i i64)
      (var j i64)
      (var k i64)
      (var n i64)
      (var nt i64)
      (var x f64)
      (var y f64)
      (var z f64)
      (var t f64)
      (var err f64)
      (var uex f64)
      (var diff f64)
      (block
        (var $$to i64)
        (var $$step i64)
        (var $$next i64)
        (= i 0)
        (= $$step 1)
        (= $$next i)
        (= $$to (- Nx 1))
        (loop
          (>= (* (- $$to $$next) $$step) 0)
          (= i $$next)
          (block
            (= x (* (cast i f64) h))
            (block
              (var $$to i64)
              (var $$step i64)
              (var $$next i64)
              (= j 0)
              (= $$step 1)
              (= $$next j)
              (= $$to (- Ny 1))
              (loop
                (>= (* (- $$to $$next) $$step) 0)
                (= j $$next)
                (block
                  (= y (* (cast j f64) h))
                  (block
                    (var $$to i64)
                    (var $$step i64)
                    (var $$next i64)
                    (= k 0)
                    (= $$step 1)
                    (= $$next k)
                    (= $$to (- Nz 1))
                    (loop
                      (>= (* (- $$to $$next) $$step) 0)
                      (= k $$next)
                      (block
                        (= z (* (cast k f64) h))
                        (= u [i j k] (* (* (call sin (* pi x)) (call sin (* pi y))) (call sin (* pi z))))
                        (= un [i j k] 0))
                      (= $$next (+ $$next $$step)))))
                (= $$next (+ $$next $$step)))))
          (= $$next (+ $$next $$step))))
      (= nt (call int (/ T dt)))
      (cond (< nt 1) (block (= nt 1)))
      (= t (* (cast nt f64) dt))
      (block
        (var $$to i64)
        (var $$step i64)
        (var $$next i64)
        (= n 0)
        (= $$step 1)
        (= $$next n)
        (= $$to (- nt 1))
        (loop
          (>= (* (- $$to $$next) $$step) 0)
          (= n $$next)
          (block
            (block
              (var $$to i64)
              (var $$step i64)
              (var $$next i64)
              (= i 1)
              (= $$step 1)
              (= $$next i)
              (= $$to (- Nx 2))
              (loop
                (>= (* (- $$to $$next) $$step) 0)
                (= i $$next)
                (block
                  (block
                    (var $$to i64)
                    (var $$step i64)
                    (var $$next i64)
                    (= j 1)
                    (= $$step 1)
                    (= $$next j)
                    (= $$to (- Ny 2))
                    (loop
                      (>= (* (- $$to $$next) $$step) 0)
                      (= j $$next)
                      (block
                        (block
                          (var $$to i64)
                          (var $$step i64)
                          (var $$next i64)
                          (= k 1)
                          (= $$step 1)
                          (= $$next k)
                          (= $$to (- Nz 2))
                          (loop
                            (>= (* (- $$to $$next) $$step) 0)
                            (= k $$next)
                            (block
                              (= un
                                [i
                                  j
                                  k]
                                (+ (index [i j k] u)
                                  (* alpha
                                    (- (+ (+ (+ (+ (+ (index [(+ i 1) j k] u) (index [(- i 1) j k] u))
                                              (index [i (+ j 1) k] u))
                                            (index [i (- j 1) k] u))
                                          (index [i j (+ k 1)] u))
                                        (index [i j (- k 1)] u))
                                      (* 6 (index [i j k] u)))))))
                            (= $$next (+ $$next $$step)))))
                      (= $$next (+ $$next $$step)))))
                (= $$next (+ $$next $$step))))
            (block
              (var $$to i64)
              (var $$step i64)
              (var $$next i64)
              (= i 1)
              (= $$step 1)
              (= $$next i)
              (= $$to (- Nx 2))
              (loop
                (>= (* (- $$to $$next) $$step) 0)
                (= i $$next)
                (block
                  (block
                    (var $$to i64)
                    (var $$step i64)
                    (var $$next i64)
                    (= j 1)
                    (= $$step 1)
                    (= $$next j)
                    (= $$to (- Ny 2))
                    (loop
                      (>= (* (- $$to $$next) $$step) 0)
                      (= j $$next)
                      (block
                        (block
                          (var $$to i64)
                          (var $$step i64)
                          (var $$next i64)
                          (= k 1)
                          (= $$step 1)
                          (= $$next k)
                          (= $$to (- Nz 2))
                          (loop
                            (>= (* (- $$to $$next) $$step) 0)
                            (= k $$next)
                            (block
                              (= u [i j k] (index [i j k] un)))
                            (= $$next (+ $$next $$step)))))
                      (= $$next (+ $$next $$step)))))
                (= $$next (+ $$next $$step)))))
          (= $$next (+ $$next $$step))))
      (var decay f64)
      (= decay (call exp (* (* (* (- 3) pi) pi) t)))
      (= err 0)
      (block
        (var $$to i64)
        (var $$step i64)
        (var $$next i64)
        (= i 0)
        (= $$step 1)
        (= $$next i)
        (= $$to (- Nx 1))
        (loop
          (>= (* (- $$to $$next) $$step) 0)
          (= i $$next)
          (block
            (= x (* (cast i f64) h))
            (block
              (var $$to i64)
              (var $$step i64)
              (var $$next i64)
              (= j 0)
              (= $$step 1)
              (= $$next j)
              (= $$to (- Ny 1))
              (loop
                (>= (* (- $$to $$next) $$step) 0)
                (= j $$next)
                (block
                  (= y (* (cast j f64) h))
                  (block
                    (var $$to i64)
                    (var $$step i64)
                    (var $$next i64)
                    (= k 0)
                    (= $$step 1)
                    (= $$next k)
                    (= $$to (- Nz 1))
                    (loop
                      (>= (* (- $$to $$next) $$step) 0)
                      (= k $$next)
                      (block
                        (= z (* (cast k f64) h))
                        (= uex (* (* (* decay (call sin (* pi x))) (call sin (* pi y))) (call sin (* pi z))))
                        (= diff (let (($$value (- (index [i j k] u) uex))) (if (< $$value 0) (- $$value) $$value)))
                        (= err (let (($$left err) ($$right diff)) (if (> $$left $$right) $$left $$right))))
                      (= $$next (+ $$next $$step)))))
                (= $$next (+ $$next $$step)))))
          (= $$next (+ $$next $$step))))
      (seq
        (call output_string "Heat3D (explicit): N=")
        (call output_int64 Nx 0)
        (call output_string ", T=")
        (call output_double t 8 8)
        (call output_string ", dt=")
        (call output_double dt 8 8)
        (call output_string ", max|u-uex|=")
        (call output_double err 8 8)
        (call output_symbol (cast 10 char)))
      (cond (< err 0.01) (block (seq (call output_string "OK\n"))) (block (seq (call output_string "FAIL\n")))))))