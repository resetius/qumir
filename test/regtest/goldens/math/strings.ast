(block
  (fun строки ()
    (block
      (block
        (call output_string "=== Конкатенация строк ===")
        (call output_string "\n"))
      (var а = (bitcast 0 string))
      (var б = (bitcast 0 string))
      (var результат = (bitcast 0 string))
      (replace а (own-literal "Привет, "))
      (replace б (own-literal "мир!"))
      (replace результат (move (call str_concat (borrow а) (borrow б))))
      (block
        (call output_string (borrow результат))
        (call output_string "\n"))
      (block
        (call output_string "\n"))
      (block
        (call output_string "=== Сравнение строк ===")
        (call output_string "\n"))
      (var строка1 = (bitcast 0 string))
      (var строка2 = (bitcast 0 string))
      (var строка3 = (bitcast 0 string))
      (replace строка1 (own-literal "яблоко"))
      (replace строка2 (own-literal "яблоко"))
      (replace строка3 (own-literal "груша"))
      (if
        (== (call str_compare (borrow строка1) (borrow строка2)) 0)
        (block
          (block
            (call output_string "строка1 = строка2: истина")
            (call output_string "\n"))))
      (if
        (== (call str_compare (borrow строка1) (borrow строка3)) 0)
        (block
          (block
            (call output_string "строка1 = строка3: истина")
            (call output_string "\n")))
        (block
          (block
            (call output_string "строка1 = строка3: ложь")
            (call output_string "\n"))))
      (if
        (< (call str_compare (borrow строка3) (borrow строка2)) 0)
        (block
          (block
            (call output_string "строка3 < строка2")
            (call output_string "\n"))))
      (block
        (call output_string "\n"))
      (block
        (call output_string "=== Юникод (получить код символа) ===")
        (call output_string "\n"))
      (var текст = (bitcast 0 string))
      (var символ_а char)
      (var код i64)
      (var код_а i64)
      (replace текст (own-literal "Привет"))
      (= код (cast (call str_symbol_at (borrow текст) 1) i64))
      (block
        (call output_string "Первый символ строки 'Привет': ")
        (call output_int64 код 0)
        (call output_string "\n"))
      (= символ_а (cast 1040 char))
      (= код_а (cast символ_а i64))
      (block
        (call output_string "Код символа 'А': ")
        (call output_int64 код_а 0)
        (call output_string "\n"))
      (block
        (call output_string "\n"))
      (block
        (call output_string "=== Юнисимвол (создать символ из кода) ===")
        (call output_string "\n"))
      (var код1 i64)
      (var код2 i64)
      (var код3 i64)
      (var код4 i64)
      (var код5 i64)
      (var код6 i64)
      (var слово = (bitcast 0 string))
      (= код1 1055)
      (= код2 1088)
      (= код3 1080)
      (= код4 1074)
      (= код5 1077)
      (= код6 1090)
      (replace
        слово
        (move
          (block
            (var __lifetime_12 = (move
                (block
                  (var __lifetime_9 = (move
                      (block
                        (var __lifetime_6 = (move
                            (block
                              (var __lifetime_3 = (move
                                  (block
                                    (var __lifetime_0 = (move (call str_from_unicode (cast код1 char))))
                                    (var __lifetime_1 = (move (call str_from_unicode (cast код2 char))))
                                    (var __lifetime_2 = (call str_concat (borrow __lifetime_0) (borrow __lifetime_1)))
                                    (destroy __lifetime_1)
                                    (destroy __lifetime_0)
                                    (move __lifetime_2))))
                              (var __lifetime_4 = (move (call str_from_unicode (cast код3 char))))
                              (var __lifetime_5 = (call str_concat (borrow __lifetime_3) (borrow __lifetime_4)))
                              (destroy __lifetime_4)
                              (destroy __lifetime_3)
                              (move __lifetime_5))))
                        (var __lifetime_7 = (move (call str_from_unicode (cast код4 char))))
                        (var __lifetime_8 = (call str_concat (borrow __lifetime_6) (borrow __lifetime_7)))
                        (destroy __lifetime_7)
                        (destroy __lifetime_6)
                        (move __lifetime_8))))
                  (var __lifetime_10 = (move (call str_from_unicode (cast код5 char))))
                  (var __lifetime_11 = (call str_concat (borrow __lifetime_9) (borrow __lifetime_10)))
                  (destroy __lifetime_10)
                  (destroy __lifetime_9)
                  (move __lifetime_11))))
            (var __lifetime_13 = (move (call str_from_unicode (cast код6 char))))
            (var __lifetime_14 = (call str_concat (borrow __lifetime_12) (borrow __lifetime_13)))
            (destroy __lifetime_13)
            (destroy __lifetime_12)
            (move __lifetime_14))))
      (block
        (call output_string "Слово из кодов: ")
        (call output_string (borrow слово))
        (call output_string "\n"))
      (block
        (call output_string "\n"))
      (block
        (call output_string "=== Индексация строк ===")
        (call output_string "\n"))
      (var фраза = (bitcast 0 string))
      (var первый = (bitcast 0 string))
      (var третий = (bitcast 0 string))
      (var подстрока = (bitcast 0 string))
      (var окончание = (bitcast 0 string))
      (var длина i64)
      (replace фраза (own-literal "Программирование"))
      (= длина (call длин (borrow фраза)))
      (block
        (call output_string "Строка: ")
        (call output_string (borrow фраза))
        (call output_string "\n"))
      (block
        (call output_string "Длина строки: ")
        (call output_int64 длина 0)
        (call output_string "\n"))
      (replace первый (move (call str_from_unicode (call str_symbol_at (borrow фраза) 1))))
      (block
        (call output_string "Первый символ (индекс 1): ")
        (call output_string (borrow первый))
        (call output_string "\n"))
      (replace третий (move (call str_from_unicode (call str_symbol_at (borrow фраза) 3))))
      (block
        (call output_string "Третий символ (индекс 3): ")
        (call output_string (borrow третий))
        (call output_string "\n"))
      (replace подстрока (move (call str_slice (borrow фраза) 1 7)))
      (block
        (call output_string "Подстрока [1:7]: ")
        (call output_string (borrow подстрока))
        (call output_string "\n"))
      (replace окончание (move (call str_slice (borrow фраза) 8 16)))
      (block
        (call output_string "Подстрока [8:16]: ")
        (call output_string (borrow окончание))
        (call output_string "\n"))
      (block
        (call output_string "\n"))
      (block
        (call output_string "=== Поиск подстроки (поз) ===")
        (call output_string "\n"))
      (var предложение = (bitcast 0 string))
      (var образец = (bitcast 0 string))
      (var не_найдено = (bitcast 0 string))
      (var позиция i64)
      (var поз_не_найден i64)
      (replace предложение (own-literal "Это тестовое предложение для теста"))
      (replace образец (own-literal "тест"))
      (= позиция (call поз (borrow предложение) (borrow образец)))
      (block
        (call output_string "Строка: ")
        (call output_string (borrow предложение))
        (call output_string "\n"))
      (block
        (call output_string "Ищем: ")
        (call output_string (borrow образец))
        (call output_string "\n"))
      (block
        (call output_string "Первое вхождение на позиции: ")
        (call output_int64 позиция 0)
        (call output_string "\n"))
      (replace не_найдено (own-literal "xyz"))
      (= поз_не_найден (call поз (borrow предложение) (borrow не_найдено)))
      (block
        (call output_string "Ищем: ")
        (call output_string (borrow не_найдено))
        (call output_string "\n"))
      (block
        (call output_string "Результат (не найдено): ")
        (call output_int64 поз_не_найден 0)
        (call output_string "\n"))
      (block
        (call output_string "\n"))
      (block
        (call output_string "=== Поиск следующего вхождения (поз после) ===")
        (call output_string "\n"))
      (var текст2 = (bitcast 0 string))
      (var образец2 = (bitcast 0 string))
      (var первая_поз i64)
      (var вторая_поз i64)
      (var третья_поз i64)
      (replace текст2 (own-literal "Это тестовое предложение для теста"))
      (replace образец2 (own-literal "тест"))
      (= первая_поз (call поз (borrow текст2) (borrow образец2)))
      (block
        (call output_string "Первое вхождение 'тест': ")
        (call output_int64 первая_поз 0)
        (call output_string "\n"))
      (= вторая_поз
        (call |поз после| (+ первая_поз 1) (borrow текст2) (borrow образец2)))
      (block
        (call output_string "Второе вхождение 'тест' (поиск после позиции ")
        (call output_int64 (+ первая_поз 1) 0)
        (call output_string "): ")
        (call output_int64 вторая_поз 0)
        (call output_string "\n"))
      (= третья_поз
        (call |поз после| (+ вторая_поз 1) (borrow текст2) (borrow образец2)))
      (block
        (call output_string "Третье вхождение (не найдено): ")
        (call output_int64 третья_поз 0)
        (call output_string "\n"))
      (block
        (call output_string "\n"))
      (block
        (call output_string "=== Все примеры выполнены ===")
        (call output_string "\n"))
      (return))))