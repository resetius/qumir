(block
  (fun |Замена а на б| ()
    (block
      (var s = (bitcast 0 string))
      (replace s (own-literal "ABCDабсвайЙЙ"))
      (var i i64)
      (for i
        1
        (call длин (borrow s))
        1
        (block
          (if
            (== (call str_symbol_at (borrow s) i) (cast 1072 char))
            (block
              (replace s (move (call str_replace_sym (borrow s) (cast 1073 char) i)))))))
      (block
        (call output_string (borrow s)))
      (cleanup-exit (return) (destroy s)))))