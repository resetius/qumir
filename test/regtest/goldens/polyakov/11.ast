(block
  (fun Обмен ()
    (block
      (var x i64)
      (= x 2)
      (var y i64)
      (= y 3)
      (call Swap x y)
      (block
        (call output_int64 x 0)
        (call output_symbol (cast 32 char))
        (call output_int64 y 0))))
  (fun Swap ((var a <ref i64>)
      (var b <ref i64>))
    (block
      (var c i64)
      (= c a)
      (= a b)
      (= b c))))