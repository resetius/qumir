(block
  (fun ЫШЧО void () ()
    (block
      (var word string)
      (= word "...")
      (call TumbaWords "ЫШЧО" word 0)))
  (fun TumbaWords void ((var A string)
      (var w0 string)
      (var N i64)) ()
    (block
      (cond (== N (call длин w0)) (block (seq (call output_string w0) (call output_string "\n")) break))
      (var i i64)
      (var w string)
      (= w (call str_slice w0 1 (call длин w0)))
      (block
        (var $$to i64)
        (var $$step i64)
        (var $$next i64)
        (= i 1)
        (= $$step 1)
        (= $$next i)
        (= $$to (call длин A))
        (loop
          (>= (* (- $$to $$next) $$step) 0)
          (= i $$next)
          (block
            (= w (call str_replace_sym w (call str_symbol_at A i) (+ N 1)))
            (call TumbaWords A w (+ N 1)))
          (= $$next (+ $$next $$step)))))))