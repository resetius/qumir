      (= s "Иван Иванович Иванов")
      (= n (call позиция (call str_from_unicode (cast 32 char)) s))
      (= name (call str_slice s 1 (- n 1)))
      (call удалить s 1 n)
      (= n (call позиция (call str_from_unicode (cast 32 char)) s))
      (= name2 (call str_slice s 1 (- n 1)))
      (call удалить s 1 n)
      (= s
