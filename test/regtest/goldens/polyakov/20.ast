(block
  (fun |Сортировка строк| void () ()
    (block
      (var i i64)
      (var j i64)
      (var N i64)
      (= N 10)
      (seq
        (var $$S_lbound0 i64)
        (var $$S_dimsize0 i64)
        (var $$S_mulacc0 i64)
        (= $$S_lbound0 1)
        (= $$S_dimsize0 (+ (- N 1) 1))
        (= $$S_mulacc0 (* 1 $$S_dimsize0))
        (var S <array string 1>))
      (var s1 string)
      (= S [1] "AAAbc")
      (= S [2] "123_33123")
      (= S [3] "-1233)1")
      (= S [4] "Вася")
      (= S [5] "петя")
      (= S [6] "Иван Иванович")
      (= S [7] "Антон")
      (= S [8] "John")
      (= S [9] "   01")
      (= S [10] "Нет")
      (block
        (var $$to i64)
        (var $$step i64)
        (var $$next i64)
        (= i 1)
        (= $$step 1)
        (= $$next i)
        (= $$to (- N 1))
        (loop
          (>= (* (- $$to $$next) $$step) 0)
          (= i $$next)
          (block
            (block
              (var $$to i64)
              (var $$step i64)
              (var $$next i64)
              (= j (- N 1))
              (= $$step (- 1))
              (= $$next j)
              (= $$to i)
              (loop
                (>= (* (- $$to $$next) $$step) 0)
                (= j $$next)
                (block
                  (cond
                    (< (call str_compare (index (+ j 1) S) (index j S)) 0)
                    (block
                      (= s1 (index j S))
                      (= S [j] (index (+ j 1) S))
                      (= S [(+ j 1)] s1))))
                (= $$next (+ $$next $$step)))))
          (= $$next (+ $$next $$step))))
      (block
        (var $$to i64)
        (var $$step i64)
        (var $$next i64)
        (= i 1)
        (= $$step 1)
        (= $$next i)
        (= $$to N)
        (loop
          (>= (* (- $$to $$next) $$step) 0)
          (= i $$next)
          (block
            (seq
              (call output_string (index i S))
              (call output_string "\n")))
          (= $$next (+ $$next $$step)))))))