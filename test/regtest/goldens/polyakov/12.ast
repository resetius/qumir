        (var $$A_mulacc0 i64)
        (= $$A_lbound0 1)
        (= $$A_dimsize0 (+ (- N 1) 1))
        (= $$A_mulacc0 (* 1 $$A_dimsize0))
        (var A <array i64 1>))
      (block
