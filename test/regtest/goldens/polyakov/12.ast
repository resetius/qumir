              (call output_int64 i 0)
              (call output_string "]=")
              (call output_string "\n"))
            (seq
              (= A [i] (call input_int64))))
          (= $$next (+ $$next $$step))))
      (block
        (var $$to i64)
        (var $$step i64)
        (var $$next i64)
        (= i 1)
        (= $$step 1)
        (= $$next i)
        (= $$to N)
        (loop
          (>= (* (- $$to $$next) $$step) 0)
