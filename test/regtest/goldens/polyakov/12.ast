      (for i 1 N 1 (block (seq (call output_int64 (index i A) 0) (call output_symbol (cast 32 char)))))
      (for i
        1
        N
        1
        (block
          (seq
            (call output_string "A[")
            (call output_int64 i 0)
            (call output_string "]=")
            (call output_string "\n"))
          (seq
