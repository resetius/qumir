        (var $$step i64)
        (var $$next i64)
        (= i 1)
        (= $$step 1)
        (= $$next i)
        (= $$to N)
        (loop (>= (* (- $$to $$next) $$step) 0) (= i $$next) (block (= A [i] (* i i))) (= $$next (+ $$next $$step))))
      (block
