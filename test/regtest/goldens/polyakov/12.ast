        (var $$next i64)
        (= i 1)
        (= $$step 1)
        (= $$next i)
        (= $$to N)
        (loop
          (>= (* (- $$to $$next) $$step) 0)
          (= i $$next)
          (block
            (seq
              (call output_int64 (index i A) 0)
              (call output_symbol (cast 32 char))))
          (= $$next (+ $$next $$step))))
      (block
        (var $$to i64)
        (var $$step i64)
        (var $$next i64)
        (= i 1)
        (= $$step 1)
        (= $$next i)
        (= $$to N)
        (loop
          (>= (* (- $$to $$next) $$step) 0)
          (= i $$next)
