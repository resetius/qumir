(block
  (use "Комплексные числа")
  (fun <main> ()
    (block
      (var x f64)
      (var y f64)
      (var n i64)
      (var a <named компл>)
      (var b <named компл>)
      (= x 3.5)
      (= a (: (call complex_from_float x) <named компл>))
      (block
        (call output_string "float_to_complex Re=")
        (call output_double (call Re (: a <named компл>)) 0 -1)
        (call output_string " Im=")
        (call output_double (call Im (: a <named компл>)) 0 -1)
        (call output_string "\n"))
      (= n 7)
      (= b (: (call complex_from_int n) <named компл>))
      (block
        (call output_string "int_to_complex Re=")
        (call output_double (call Re (: b <named компл>)) 0 -1)
        (call output_string " Im=")
        (call output_double (call Im (: b <named компл>)) 0 -1)
        (call output_string "\n"))
      (= y (call complex_to_float (: a <named компл>)))
      (block
        (call output_string "complex_to_float=")
        (call output_double y 0 -1)
        (call output_string "\n"))
      (= n (call complex_to_int (: a <named компл>)))
      (block
        (call output_string "complex_to_int=")
        (call output_int64 n 0)
        (call output_string "\n"))
      (cleanup-exit (return)))))