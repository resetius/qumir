(block
  (use "Комплексные числа")
  (fun <main> ()
    (block
      (var z <named компл>)
      (= z
        (: (call complex_add (: (call complex_from_float 3) <named компл>) (: (call __imag 4) <named компл>))
          <named компл>))
      (block
        (call complex_print (: z <named компл>))
        (call output_string "\n"))
      (= z
        (: (call complex_sub (: (call complex_from_float 3) <named компл>) (: (call __imag 4) <named компл>))
          <named компл>))
      (block
        (call complex_print (: z <named компл>))
        (call output_string "\n"))
      (= z (: (call __imag 2) <named компл>))
      (block
        (call complex_print (: z <named компл>))
        (call output_string "\n"))
      (cleanup-exit (return)))))