(block
  (use "Комплексные числа")
  (fun <main> void () ()
    (block
      (var z <named компл>)
      (= z (: (struct ((re 0) (im 2))) <named компл>))
      (seq
        (call output_string "2i: Re=")
        (call output_double (field (: z <named компл>) re) 0 -1)
        (call output_string " Im=")
        (call output_double (field (: z <named компл>) im) 0 -1)
        (call output_string "\n"))
      (= z (: (struct ((re 0) (im 3.5))) <named компл>))
      (seq
        (call output_string "3.5i: Re=")
        (call output_double (field (: z <named компл>) re) 0 -1)
        (call output_string " Im=")
        (call output_double (field (: z <named компл>) im) 0 -1)
        (call output_string "\n"))
      (= z
        (: (struct ((re (+ (field (: (struct ((re 0) (im 2))) <named компл>) re)
                (field (: (struct ((re (cast 10 f64)) (im 0))) <named компл>) re)))
              (im (+ (field (: (struct ((re 0) (im 2))) <named компл>) im)
                (field (: (struct ((re (cast 10 f64)) (im 0))) <named компл>) im)))))
          <named компл>))
      (seq
        (call output_string "2i+10: Re=")
        (call output_double (field (: z <named компл>) re) 0 -1)
        (call output_string " Im=")
        (call output_double (field (: z <named компл>) im) 0 -1)
        (call output_string "\n"))
      (= z
        (: (struct ((re (- (* (field (: (struct ((re 0) (im 1))) <named компл>) re)
                  (field (: (struct ((re 0) (im 1))) <named компл>) re))
                (* (field (: (struct ((re 0) (im 1))) <named компл>) im)
                  (field (: (struct ((re 0) (im 1))) <named компл>) im))))
              (im (+ (* (field (: (struct ((re 0) (im 1))) <named компл>) re)
                  (field (: (struct ((re 0) (im 1))) <named компл>) im))
                (* (field (: (struct ((re 0) (im 1))) <named компл>) im)
                  (field (: (struct ((re 0) (im 1))) <named компл>) re))))))
          <named компл>))
      (seq
        (call output_string "i*i: Re=")
        (call output_double (field (: z <named компл>) re) 0 -1)
        (call output_string " Im=")
        (call output_double (field (: z <named компл>) im) 0 -1)
        (call output_string "\n")))))