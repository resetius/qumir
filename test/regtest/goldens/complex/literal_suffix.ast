(block
  (use "Комплексные числа")
  (fun <main> ()
    (block
      (var z <named компл>)
      (= z (: (call __imag 2) <named компл>))
      (block
        (call output_string "2i: Re=")
        (call output_double (call Re (: z <named компл>)) 0 -1)
        (call output_string " Im=")
        (call output_double (call Im (: z <named компл>)) 0 -1)
        (call output_string "\n"))
      (= z (: (call __imag 3.5) <named компл>))
      (block
        (call output_string "3.5i: Re=")
        (call output_double (call Re (: z <named компл>)) 0 -1)
        (call output_string " Im=")
        (call output_double (call Im (: z <named компл>)) 0 -1)
        (call output_string "\n"))
      (= z
        (: (call complex_add (: (call __imag 2) <named компл>) (: (call complex_from_int 10) <named компл>))
          <named компл>))
      (block
        (call output_string "2i+10: Re=")
        (call output_double (call Re (: z <named компл>)) 0 -1)
        (call output_string " Im=")
        (call output_double (call Im (: z <named компл>)) 0 -1)
        (call output_string "\n"))
      (= z
        (: (call complex_mul (: (call __imag 1) <named компл>) (: (call __imag 1) <named компл>))
          <named компл>))
      (block
        (call output_string "i*i: Re=")
        (call output_double (call Re (: z <named компл>)) 0 -1)
        (call output_string " Im=")
        (call output_double (call Im (: z <named компл>)) 0 -1)
        (call output_string "\n"))
      (cleanup-exit (return)))))