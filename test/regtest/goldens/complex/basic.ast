(block
  (use "Комплексные числа")
  (fun <main> ()
    (block
      (var z <named компл>)
      (= z (: (call i) <named компл>))
      (block
        (call output_string "i Re=")
        (call output_double (call Re (: z <named компл>)) 0 -1)
        (call output_string " Im=")
        (call output_double (call Im (: z <named компл>)) 0 -1)
        (call output_string "\n"))
      (cleanup-exit (return)))))