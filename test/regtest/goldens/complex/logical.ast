(block
  (use "Комплексные числа")
  (fun <main> ()
    (block
      (var a <named компл>)
      (var b <named компл>)
      (var same bool)
      (var different bool)
      (= a
        (: (struct ((re (+ (field (: (struct ((re 2) (im 0))) <named компл>) re)
                (field
                  (: (struct ((re (- (* (field (: (struct ((re 3) (im 0))) <named компл>) re)
                            (field (: (struct ((re 0) (im 1))) <named компл>) re))
                          (* (field (: (struct ((re 3) (im 0))) <named компл>) im)
                            (field (: (struct ((re 0) (im 1))) <named компл>) im))))
                        (im (+ (* (field (: (struct ((re 3) (im 0))) <named компл>) re)
                            (field (: (struct ((re 0) (im 1))) <named компл>) im))
                          (* (field (: (struct ((re 3) (im 0))) <named компл>) im)
                            (field (: (struct ((re 0) (im 1))) <named компл>) re))))))
                    <named компл>)
                  re)))
              (im (+ (field (: (struct ((re 2) (im 0))) <named компл>) im)
                (field
                  (: (struct ((re (- (* (field (: (struct ((re 3) (im 0))) <named компл>) re)
                            (field (: (struct ((re 0) (im 1))) <named компл>) re))
                          (* (field (: (struct ((re 3) (im 0))) <named компл>) im)
                            (field (: (struct ((re 0) (im 1))) <named компл>) im))))
                        (im (+ (* (field (: (struct ((re 3) (im 0))) <named компл>) re)
                            (field (: (struct ((re 0) (im 1))) <named компл>) im))
                          (* (field (: (struct ((re 3) (im 0))) <named компл>) im)
                            (field (: (struct ((re 0) (im 1))) <named компл>) re))))))
                    <named компл>)
                  im)))))
          <named компл>))
      (= b
        (: (struct ((re (+ (field (: (struct ((re 2) (im 0))) <named компл>) re)
                (field
                  (: (struct ((re (- (* (field (: (struct ((re 4) (im 0))) <named компл>) re)
                            (field (: (struct ((re 0) (im 1))) <named компл>) re))
                          (* (field (: (struct ((re 4) (im 0))) <named компл>) im)
                            (field (: (struct ((re 0) (im 1))) <named компл>) im))))
                        (im (+ (* (field (: (struct ((re 4) (im 0))) <named компл>) re)
                            (field (: (struct ((re 0) (im 1))) <named компл>) im))
                          (* (field (: (struct ((re 4) (im 0))) <named компл>) im)
                            (field (: (struct ((re 0) (im 1))) <named компл>) re))))))
                    <named компл>)
                  re)))
              (im (+ (field (: (struct ((re 2) (im 0))) <named компл>) im)
                (field
                  (: (struct ((re (- (* (field (: (struct ((re 4) (im 0))) <named компл>) re)
                            (field (: (struct ((re 0) (im 1))) <named компл>) re))
                          (* (field (: (struct ((re 4) (im 0))) <named компл>) im)
                            (field (: (struct ((re 0) (im 1))) <named компл>) im))))
                        (im (+ (* (field (: (struct ((re 4) (im 0))) <named компл>) re)
                            (field (: (struct ((re 0) (im 1))) <named компл>) im))
                          (* (field (: (struct ((re 4) (im 0))) <named компл>) im)
                            (field (: (struct ((re 0) (im 1))) <named компл>) re))))))
                    <named компл>)
                  im)))))
          <named компл>))
      (= same
        (&& (== (field (: a <named компл>) re) (field (: a <named компл>) re))
          (== (field (: a <named компл>) im) (field (: a <named компл>) im))))
      (= different
        (|| (!= (field (: a <named компл>) re) (field (: b <named компл>) re))
          (!= (field (: a <named компл>) im) (field (: b <named компл>) im))))
      (seq
        (call output_string "and=")
        (call output_bool (&& same different))
        (call output_string "\n"))
      (seq
        (call output_string "or=")
        (call
          output_bool
          (|| same
            (&& (== (field (: a <named компл>) re) (field (: b <named компл>) re))
              (== (field (: a <named компл>) im) (field (: b <named компл>) im)))))
        (call output_string "\n"))
      (seq
        (call output_string "not=")
        (call
          output_bool
          (! (&& (== (field (: a <named компл>) re) (field (: b <named компл>) re))
              (== (field (: a <named компл>) im) (field (: b <named компл>) im)))))
        (call output_string "\n")))))