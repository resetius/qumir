(block
  (use "Комплексные числа")
  (fun <main> ()
    (block
      (var a <named компл>)
      (var b <named компл>)
      (var same bool)
      (var different bool)
      (= a
        (: (call
            complex_add
            (: (call complex_from_float 2) <named компл>)
            (: (call complex_mul (: (call complex_from_float 3) <named компл>) (: (call i) <named компл>))
              <named компл>))
          <named компл>))
      (= b
        (: (call
            complex_add
            (: (call complex_from_float 2) <named компл>)
            (: (call complex_mul (: (call complex_from_float 4) <named компл>) (: (call i) <named компл>))
              <named компл>))
          <named компл>))
      (= same (call complex_eq (: a <named компл>) (: a <named компл>)))
      (= different (call complex_ne (: a <named компл>) (: b <named компл>)))
      (block
        (call output_string "and=")
        (call output_bool (&& same different))
        (call output_string "\n"))
      (block
        (call output_string "or=")
        (call output_bool (|| same (call complex_eq (: a <named компл>) (: b <named компл>))))
        (call output_string "\n"))
      (block
        (call output_string "not=")
        (call output_bool (! (call complex_eq (: a <named компл>) (: b <named компл>))))
        (call output_string "\n"))
      (cleanup-exit (return)))))