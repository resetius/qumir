(block
  (use "Комплексные числа")
  (fun <main> ()
    (block
      (var arr <array <named компл> 1> [0 2])
      (var j i64)
      (for j
        0
        2
        1
        (block
          (= arr
            [j]
            (: (call complex_add (: (call complex_from_int j) <named компл>) (: (call i) <named компл>))
              <named компл>))))
      (for j
        0
        2
        1
        (block
          (block
            (call output_string "arr[")
            (call output_int64 j 0)
            (call output_string "] Re=")
            (call output_double (call Re (: (index arr j) <named компл>)) 0 -1)
            (call output_string " Im=")
            (call output_double (call Im (: (index arr j) <named компл>)) 0 -1)
            (call output_string "\n"))))
      (cleanup-exit (return) (destroy arr)))))