(block
  (use "Комплексные числа")
  (fun main ()
    (block
      (var a <named компл>)
      (var b <named компл>)
      (= a (: (call make_complex 2 5) <named компл>))
      (block
        (call output_string "arg Re=")
        (call output_double (call real_part (: a <named компл>)) 0 -1)
        (call output_string " Im=")
        (call output_double (call imag_part (: a <named компл>)) 0 -1)
        (call output_string "\n"))
      (= b (: (call add_twice (: a <named компл>) (: (call i) <named компл>)) <named компл>))
      (block
        (call output_string "return Re=")
        (call output_double (call Re (: b <named компл>)) 0 -1)
        (call output_string " Im=")
        (call output_double (call Im (: b <named компл>)) 0 -1)
        (call output_string "\n"))
      (cleanup-exit (return))))
  (fun real_part ((var z <named компл (readonly)>)) -> f64
    (block
      (var знач f64)
      (= знач (call Re (: z <named компл (readonly)>)))
      (cleanup-exit (return знач))))
  (fun imag_part ((var z <named компл (readonly)>)) -> f64
    (block
      (var знач f64)
      (= знач (call Im (: z <named компл (readonly)>)))
      (cleanup-exit (return знач))))
  (fun make_complex ((var re <f64 (readonly)>)
      (var im <f64 (readonly)>)) -> <named компл>
    (block
      (var знач <named компл>)
      (= знач
        (: (call
            complex_add
            (: (call complex_from_float re) <named компл>)
            (: (call complex_mul (: (call complex_from_float im) <named компл>) (: (call i) <named компл>))
              <named компл>))
          <named компл>))
      (cleanup-exit (return (: знач <named компл>)))))
  (fun add_twice ((var a <named компл (readonly)>)
      (var b <named компл (readonly)>)) -> <named компл>
    (block
      (var знач <named компл>)
      (= знач
        (: (call
            complex_add
            (: (call complex_add (: a <named компл (readonly)>) (: b <named компл (readonly)>))
              <named компл>)
            (: b <named компл (readonly)>))
          <named компл>))
      (cleanup-exit (return (: знач <named компл>))))))