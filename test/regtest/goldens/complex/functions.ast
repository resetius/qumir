(block
  (use "Комплексные числа")
  (fun main void () ()
    (block
      (var a <named компл>)
      (var b <named компл>)
      (= a (: (call make_complex 2 5) <named компл>))
      (seq
        (call output_string "arg Re=")
        (call output_double (call real_part (: a <named компл>)) 0 -1)
        (call output_string " Im=")
        (call output_double (call imag_part (: a <named компл>)) 0 -1)
        (call output_string "\n"))
      (= b
        (: (call add_twice (: a <named компл>) (: (struct ((re 0) (im 1))) <named компл>)) <named компл>))
      (seq
        (call output_string "return Re=")
        (call output_double (field (: b <named компл>) re) 0 -1)
        (call output_string " Im=")
        (call output_double (field (: b <named компл>) im) 0 -1)
        (call output_string "\n"))))
  (fun real_part f64 ((var z <named компл>)) ()
    (block
      (var $$return f64)
      (= $$return (field (: z <named компл>) re))))
  (fun imag_part f64 ((var z <named компл>)) ()
    (block
      (var $$return f64)
      (= $$return (field (: z <named компл>) im))))
  (fun make_complex <named компл> ((var re f64)
      (var im f64)) ()
    (block
      (var $$return <named компл>)
      (= $$return
        (: (struct ((re (+ (field (: (struct ((re re) (im 0))) <named компл>) re)
                (field
                  (: (struct ((re (- (* (field (: (struct ((re im) (im 0))) <named компл>) re)
                            (field (: (struct ((re 0) (im 1))) <named компл>) re))
                          (* (field (: (struct ((re im) (im 0))) <named компл>) im)
                            (field (: (struct ((re 0) (im 1))) <named компл>) im))))
                        (im (+ (* (field (: (struct ((re im) (im 0))) <named компл>) re)
                            (field (: (struct ((re 0) (im 1))) <named компл>) im))
                          (* (field (: (struct ((re im) (im 0))) <named компл>) im)
                            (field (: (struct ((re 0) (im 1))) <named компл>) re))))))
                    <named компл>)
                  re)))
              (im (+ (field (: (struct ((re re) (im 0))) <named компл>) im)
                (field
                  (: (struct ((re (- (* (field (: (struct ((re im) (im 0))) <named компл>) re)
                            (field (: (struct ((re 0) (im 1))) <named компл>) re))
                          (* (field (: (struct ((re im) (im 0))) <named компл>) im)
                            (field (: (struct ((re 0) (im 1))) <named компл>) im))))
                        (im (+ (* (field (: (struct ((re im) (im 0))) <named компл>) re)
                            (field (: (struct ((re 0) (im 1))) <named компл>) im))
                          (* (field (: (struct ((re im) (im 0))) <named компл>) im)
                            (field (: (struct ((re 0) (im 1))) <named компл>) re))))))
                    <named компл>)
                  im)))))
          <named компл>))))
  (fun add_twice <named компл> ((var a <named компл>)
      (var b <named компл>)) ()
    (block
      (var $$return <named компл>)
      (= $$return
        (: (struct ((re (+ (field
                  (: (struct ((re (+ (field (: a <named компл>) re) (field (: b <named компл>) re)))
                        (im (+ (field (: a <named компл>) im) (field (: b <named компл>) im)))))
                    <named компл>)
                  re)
                (field (: b <named компл>) re)))
              (im (+ (field
                  (: (struct ((re (+ (field (: a <named компл>) re) (field (: b <named компл>) re)))
                        (im (+ (field (: a <named компл>) im) (field (: b <named компл>) im)))))
                    <named компл>)
                  im)
                (field (: b <named компл>) im)))))
          <named компл>)))))