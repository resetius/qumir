(block
  (use "Комплексные числа")
  (fun main ()
    (block
      (var z <named компл>)
      (var re f64)
      (var im f64)
      (call make_by_ref 4 6 (: z <named компл>))
      (call split (: z <named компл>) re im)
      (block
        (call output_string "made Re=")
        (call output_double re 0 -1)
        (call output_string " Im=")
        (call output_double im 0 -1)
        (call output_string "\n"))
      (call add_in_place (: z <named компл>) (: (call i) <named компл>))
      (block
        (call output_string "updated Re=")
        (call output_double (call Re (: z <named компл>)) 0 -1)
        (call output_string " Im=")
        (call output_double (call Im (: z <named компл>)) 0 -1)
        (call output_string "\n"))
      (cleanup-exit (return))))
  (fun split ((var z <named компл (readonly)>)
      (var re <ref <f64 (writeonly)>>)
      (var im <ref <f64 (writeonly)>>))
    (block
      (= re (call Re (: z <named компл (readonly)>)))
      (= im (call Im (: z <named компл (readonly)>)))
      (cleanup-exit (return))))
  (fun make_by_ref ((var re <f64 (readonly)>)
      (var im <f64 (readonly)>)
      (var z <ref <named компл (writeonly)>>))
    (block
      (= z
        (: (call
            complex_add
            (: (call complex_from_float re) <named компл>)
            (: (call complex_mul (: (call complex_from_float im) <named компл>) (: (call i) <named компл>))
              <named компл>))
          <named компл>))
      (cleanup-exit (return))))
  (fun add_in_place ((var z <ref <named компл>>)
      (var delta <named компл (readonly)>))
    (block
      (= z (: (call complex_add z (: delta <named компл (readonly)>)) <named компл>))
      (cleanup-exit (return)))))