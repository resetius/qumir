(block
  (use "Комплексные числа")
  (fun main void () ()
    (block
      (var z <named компл>)
      (var re f64)
      (var im f64)
      (call make_by_ref 4 6 (: z <named компл>))
      (call split (: z <named компл>) re im)
      (seq
        (call output_string "made Re=")
        (call output_double re 0 -1)
        (call output_string " Im=")
        (call output_double im 0 -1)
        (call output_string "\n"))
      (call add_in_place (: z <named компл>) (: (struct ((re 0) (im 1))) <named компл>))
      (seq
        (call output_string "updated Re=")
        (call output_double (field (: z <named компл>) re) 0 -1)
        (call output_string " Im=")
        (call output_double (field (: z <named компл>) im) 0 -1)
        (call output_string "\n"))))
  (fun split void ((var z <named компл>)
      (var re <ref <f64 (mutable)>>)
      (var im <ref <f64 (mutable)>>)) ()
    (block
      (= re (field (: z <named компл>) re))
      (= im (field (: z <named компл>) im))))
  (fun make_by_ref void ((var re f64)
      (var im f64)
      (var z <ref <named компл>>)) ()
    (block
      (= z
        (: (struct ((re (+ (field (: (struct ((re re) (im 0))) <named компл>) re)
                (field
                  (: (struct ((re (- (* (field (: (struct ((re im) (im 0))) <named компл>) re)
                            (field (: (struct ((re 0) (im 1))) <named компл>) re))
                          (* (field (: (struct ((re im) (im 0))) <named компл>) im)
                            (field (: (struct ((re 0) (im 1))) <named компл>) im))))
                        (im (+ (* (field (: (struct ((re im) (im 0))) <named компл>) re)
                            (field (: (struct ((re 0) (im 1))) <named компл>) im))
                          (* (field (: (struct ((re im) (im 0))) <named компл>) im)
                            (field (: (struct ((re 0) (im 1))) <named компл>) re))))))
                    <named компл>)
                  re)))
              (im (+ (field (: (struct ((re re) (im 0))) <named компл>) im)
                (field
                  (: (struct ((re (- (* (field (: (struct ((re im) (im 0))) <named компл>) re)
                            (field (: (struct ((re 0) (im 1))) <named компл>) re))
                          (* (field (: (struct ((re im) (im 0))) <named компл>) im)
                            (field (: (struct ((re 0) (im 1))) <named компл>) im))))
                        (im (+ (* (field (: (struct ((re im) (im 0))) <named компл>) re)
                            (field (: (struct ((re 0) (im 1))) <named компл>) im))
                          (* (field (: (struct ((re im) (im 0))) <named компл>) im)
                            (field (: (struct ((re 0) (im 1))) <named компл>) re))))))
                    <named компл>)
                  im)))))
          <named компл>))))
  (fun add_in_place void ((var z <ref <named компл>>)
      (var delta <named компл>)) ()
    (block
      (= z
        (: (struct ((re (+ (field z re) (field (: delta <named компл>) re)))
              (im (+ (field z im) (field (: delta <named компл>) im)))))
          <named компл>)))))