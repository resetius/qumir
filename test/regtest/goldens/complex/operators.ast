(block
  (use "Комплексные числа")
  (fun <main> ()
    (block
      (var a <named компл>)
      (var b <named компл>)
      (var c <named компл>)
      (= a
        (: (struct ((re (+ (field (: (struct ((re 1) (im 0))) <named компл>) re)
                (field
                  (: (struct ((re (- (* (field (: (struct ((re 2) (im 0))) <named компл>) re)
                            (field (: (struct ((re 0) (im 1))) <named компл>) re))
                          (* (field (: (struct ((re 2) (im 0))) <named компл>) im)
                            (field (: (struct ((re 0) (im 1))) <named компл>) im))))
                        (im (+ (* (field (: (struct ((re 2) (im 0))) <named компл>) re)
                            (field (: (struct ((re 0) (im 1))) <named компл>) im))
                          (* (field (: (struct ((re 2) (im 0))) <named компл>) im)
                            (field (: (struct ((re 0) (im 1))) <named компл>) re))))))
                    <named компл>)
                  re)))
              (im (+ (field (: (struct ((re 1) (im 0))) <named компл>) im)
                (field
                  (: (struct ((re (- (* (field (: (struct ((re 2) (im 0))) <named компл>) re)
                            (field (: (struct ((re 0) (im 1))) <named компл>) re))
                          (* (field (: (struct ((re 2) (im 0))) <named компл>) im)
                            (field (: (struct ((re 0) (im 1))) <named компл>) im))))
                        (im (+ (* (field (: (struct ((re 2) (im 0))) <named компл>) re)
                            (field (: (struct ((re 0) (im 1))) <named компл>) im))
                          (* (field (: (struct ((re 2) (im 0))) <named компл>) im)
                            (field (: (struct ((re 0) (im 1))) <named компл>) re))))))
                    <named компл>)
                  im)))))
          <named компл>))
      (= b
        (: (struct ((re (+ (field (: (struct ((re 3) (im 0))) <named компл>) re)
                (field
                  (: (struct ((re (- (* (field (: (struct ((re 4) (im 0))) <named компл>) re)
                            (field (: (struct ((re 0) (im 1))) <named компл>) re))
                          (* (field (: (struct ((re 4) (im 0))) <named компл>) im)
                            (field (: (struct ((re 0) (im 1))) <named компл>) im))))
                        (im (+ (* (field (: (struct ((re 4) (im 0))) <named компл>) re)
                            (field (: (struct ((re 0) (im 1))) <named компл>) im))
                          (* (field (: (struct ((re 4) (im 0))) <named компл>) im)
                            (field (: (struct ((re 0) (im 1))) <named компл>) re))))))
                    <named компл>)
                  re)))
              (im (+ (field (: (struct ((re 3) (im 0))) <named компл>) im)
                (field
                  (: (struct ((re (- (* (field (: (struct ((re 4) (im 0))) <named компл>) re)
                            (field (: (struct ((re 0) (im 1))) <named компл>) re))
                          (* (field (: (struct ((re 4) (im 0))) <named компл>) im)
                            (field (: (struct ((re 0) (im 1))) <named компл>) im))))
                        (im (+ (* (field (: (struct ((re 4) (im 0))) <named компл>) re)
                            (field (: (struct ((re 0) (im 1))) <named компл>) im))
                          (* (field (: (struct ((re 4) (im 0))) <named компл>) im)
                            (field (: (struct ((re 0) (im 1))) <named компл>) re))))))
                    <named компл>)
                  im)))))
          <named компл>))
      (= c
        (: (struct ((re (+ (field (: a <named компл>) re) (field (: b <named компл>) re)))
              (im (+ (field (: a <named компл>) im) (field (: b <named компл>) im)))))
          <named компл>))
      (block
        (call output_string "add Re=")
        (call output_double (field (: c <named компл>) re) 0 -1)
        (call output_string " Im=")
        (call output_double (field (: c <named компл>) im) 0 -1)
        (call output_string "\n"))
      (= c
        (: (struct ((re (- (field (: b <named компл>) re) (field (: a <named компл>) re)))
              (im (- (field (: b <named компл>) im) (field (: a <named компл>) im)))))
          <named компл>))
      (block
        (call output_string "sub Re=")
        (call output_double (field (: c <named компл>) re) 0 -1)
        (call output_string " Im=")
        (call output_double (field (: c <named компл>) im) 0 -1)
        (call output_string "\n"))
      (= c
        (: (struct ((re (- (* (field (: a <named компл>) re) (field (: b <named компл>) re))
                (* (field (: a <named компл>) im) (field (: b <named компл>) im))))
              (im (+ (* (field (: a <named компл>) re) (field (: b <named компл>) im))
                (* (field (: a <named компл>) im) (field (: b <named компл>) re))))))
          <named компл>))
      (block
        (call output_string "mul Re=")
        (call output_double (field (: c <named компл>) re) 0 -1)
        (call output_string " Im=")
        (call output_double (field (: c <named компл>) im) 0 -1)
        (call output_string "\n"))
      (= c
        (: (struct ((re (/ (+ (* (field (: b <named компл>) re) (field (: a <named компл>) re))
                  (* (field (: b <named компл>) im) (field (: a <named компл>) im)))
                (+ (* (field (: a <named компл>) re) (field (: a <named компл>) re))
                  (* (field (: a <named компл>) im) (field (: a <named компл>) im)))))
              (im (/ (- (* (field (: b <named компл>) im) (field (: a <named компл>) re))
                  (* (field (: b <named компл>) re) (field (: a <named компл>) im)))
                (+ (* (field (: a <named компл>) re) (field (: a <named компл>) re))
                  (* (field (: a <named компл>) im) (field (: a <named компл>) im)))))))
          <named компл>))
      (block
        (call output_string "div Re=")
        (call output_double (field (: c <named компл>) re) 0 -1)
        (call output_string " Im=")
        (call output_double (field (: c <named компл>) im) 0 -1)
        (call output_string "\n"))
      (= c
        (: (struct ((re (- (field (: a <named компл>) re))) (im (- (field (: a <named компл>) im)))))
          <named компл>))
      (block
        (call output_string "neg Re=")
        (call output_double (field (: c <named компл>) re) 0 -1)
        (call output_string " Im=")
        (call output_double (field (: c <named компл>) im) 0 -1)
        (call output_string "\n")))))