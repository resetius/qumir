(block
  (use "Комплексные числа")
  (fun <main> ()
    (block
      (var a <named компл>)
      (var b <named компл>)
      (var c <named компл>)
      (= a
        (: (call
            complex_add
            (: (call complex_from_float 1) <named компл>)
            (: (call complex_mul (: (call complex_from_float 2) <named компл>) (: (call i) <named компл>))
              <named компл>))
          <named компл>))
      (= b
        (: (call
            complex_add
            (: (call complex_from_float 3) <named компл>)
            (: (call complex_mul (: (call complex_from_float 4) <named компл>) (: (call i) <named компл>))
              <named компл>))
          <named компл>))
      (= c (: (call complex_add (: a <named компл>) (: b <named компл>)) <named компл>))
      (block
        (call output_string "add Re=")
        (call output_double (call Re (: c <named компл>)) 0 -1)
        (call output_string " Im=")
        (call output_double (call Im (: c <named компл>)) 0 -1)
        (call output_string "\n"))
      (= c (: (call complex_sub (: b <named компл>) (: a <named компл>)) <named компл>))
      (block
        (call output_string "sub Re=")
        (call output_double (call Re (: c <named компл>)) 0 -1)
        (call output_string " Im=")
        (call output_double (call Im (: c <named компл>)) 0 -1)
        (call output_string "\n"))
      (= c (: (call complex_mul (: a <named компл>) (: b <named компл>)) <named компл>))
      (block
        (call output_string "mul Re=")
        (call output_double (call Re (: c <named компл>)) 0 -1)
        (call output_string " Im=")
        (call output_double (call Im (: c <named компл>)) 0 -1)
        (call output_string "\n"))
      (= c (: (call complex_div (: b <named компл>) (: a <named компл>)) <named компл>))
      (block
        (call output_string "div Re=")
        (call output_double (call Re (: c <named компл>)) 0 -1)
        (call output_string " Im=")
        (call output_double (call Im (: c <named компл>)) 0 -1)
        (call output_string "\n"))
      (= c (: (call complex_neg (: a <named компл>)) <named компл>))
      (block
        (call output_string "neg Re=")
        (call output_double (call Re (: c <named компл>)) 0 -1)
        (call output_string " Im=")
        (call output_double (call Im (: c <named компл>)) 0 -1)
        (call output_string "\n"))
      (cleanup-exit (return)))))