(block
  (use "Комплексные числа")
  (fun <main> ()
    (block
      (var a <named компл>)
      (var b <named компл>)
      (= a
        (: (call
            complex_add
            (: (call complex_from_float 1) <named компл>)
            (: (call complex_mul (: (call complex_from_float 2) <named компл>) (: (call i) <named компл>))
              <named компл>))
          <named компл>))
      (= b
        (: (call
            complex_add
            (: (call complex_from_float 1) <named компл>)
            (: (call complex_mul (: (call complex_from_float 3) <named компл>) (: (call i) <named компл>))
              <named компл>))
          <named компл>))
      (block
        (call output_string "eq_same=")
        (call output_bool (call complex_eq (: a <named компл>) (: a <named компл>)))
        (call output_string "\n"))
      (block
        (call output_string "eq_other=")
        (call output_bool (call complex_eq (: a <named компл>) (: b <named компл>)))
        (call output_string "\n"))
      (block
        (call output_string "ne_other=")
        (call output_bool (call complex_ne (: a <named компл>) (: b <named компл>)))
        (call output_string "\n"))
      (cleanup-exit (return)))))