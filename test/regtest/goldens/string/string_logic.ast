(block
  (fun тест_логика_строки_символы i64 () ()
    (block
      (var $$return i64)
      (var s1 string)
      (var s2 string)
      (var ch1 char)
      (var ch2 char)
      (= s1 "alpha")
      (= s2 "alpha")
      (= ch1 (cast 97 char))
      (= ch2 (cast 122 char))
      (var счет i64)
      (= счет 0)
      (cond (== (call str_compare s1 s2) 0) (block (= счет (+ счет 1))))
      (cond (== (call str_compare s1 (call str_from_unicode ch1)) 0) (block (= счет (+ счет 1000))))
      (cond (== ch1 (cast 97 char)) (block (= счет (+ счет 1))))
      (cond (!= (call str_compare s1 s2) 0) (block (= счет (+ счет 1000))))
      (cond (!= ch1 ch2) (block (= счет (+ счет 1))))
      (cond (!= ch2 (cast 122 char)) (block (= счет (+ счет 1000))))
      (cond (< (call str_compare s1 "beta") 0) (block (= счет (+ счет 1))))
      (cond (<= (call str_compare s2 "alpha") 0) (block (= счет (+ счет 1))))
      (cond (> (call str_compare "beta" s1) 0) (block (= счет (+ счет 1))))
      (cond (>= (call str_compare "alpha" s2) 0) (block (= счет (+ счет 1))))
      (cond (< ch1 ch2) (block (= счет (+ счет 1))))
      (cond (> ch2 ch1) (block (= счет (+ счет 1))))
      (cond (<= ch1 (cast 97 char)) (block (= счет (+ счет 1))))
      (cond (>= ch2 (cast 122 char)) (block (= счет (+ счет 1))))
      (= $$return счет))))