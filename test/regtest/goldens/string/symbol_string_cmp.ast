(block
  (fun тест_сравнение_символ_строка () -> i64
    (block
      (var $$return i64)
      (var c char)
      (var s string)
      (= c (cast 97 char))
      (= s (call str_from_unicode (cast 97 char)))
      (var r i64)
      (= r 0)
      (cond (== (call str_compare (call str_from_unicode c) s) 0) (block (= r (+ r 1))))
      (cond (!= (call str_compare (call str_from_unicode c) s) 0) (block (= r (+ r 1000))))
      (cond (<= (call str_compare (call str_from_unicode c) s) 0) (block (= r (+ r 1))))
      (cond (>= (call str_compare (call str_from_unicode c) s) 0) (block (= r (+ r 1))))
      (cond (< c (cast 98 char)) (block (= r (+ r 1))))
      (cond (> c (cast 96 char)) (block (= r (+ r 1))))
      (= $$return r))))