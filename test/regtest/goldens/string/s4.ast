(block
  (fun main string () ()
    (block
      (var $$return string)
      (var s string)
      (= s (call str_concat "11 " "10"))
      (= s (call ф 10))
      (= $$return s)))
  (fun ф string ((var k i64)) ()
    (block
      (var $$return string)
      (var стр string)
      (var i i64)
      (var j i64)
      (= стр "ыыы")
      (= $$return стр)
      (= j 0)
      (block
        (var $$to i64)
        (var $$step i64)
        (var $$next i64)
        (= i 0)
        (= $$step 1)
        (= $$next i)
        (= $$to 10)
        (loop (>= (* (- $$to $$next) $$step) 0) (= i $$next) (block (= j (+ j 1))) (= $$next (+ $$next $$step)))))))