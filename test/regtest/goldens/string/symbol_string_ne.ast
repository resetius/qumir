(block
  (fun тест_неравенство_символ_строка i64 () ()
    (block
      (var $$return i64)
      (var x char)
      (var t string)
      (= x (cast 98 char))
      (= t (call str_from_unicode (cast 99 char)))
      (var r i64)
      (= r 0)
      (cond (!= (call str_compare (call str_from_unicode x) t) 0) (block (= r (+ r 1))))
      (cond (== (call str_compare (call str_from_unicode x) t) 0) (block (= r (+ r 1000))))
      (cond (< (call str_compare (call str_from_unicode x) t) 0) (block (= r (+ r 1))))
      (cond (> (call str_compare t (call str_from_unicode x)) 0) (block (= r (+ r 1))))
      (= $$return r))))