(block
  (fun тест_граничные_пустая_строка () -> i64
    (block
      (var знач i64)
      (var пустая = (bitcast 0 string))
      (var непустая = (bitcast 0 string))
      (replace пустая (own-literal ""))
      (replace непустая (move (call str_from_unicode (cast 97 char))))
      (var r i64)
      (= r 0)
      (if (< (call str_compare (borrow пустая) (borrow непустая)) 0) (block (= r (+ r 1))))
      (if (<= (call str_compare (borrow пустая) (borrow непустая)) 0) (block (= r (+ r 1))))
      (if (> (call str_compare (borrow непустая) (borrow пустая)) 0) (block (= r (+ r 1))))
      (if (>= (call str_compare (borrow непустая) (borrow пустая)) 0) (block (= r (+ r 1))))
      (if
        (== (block
            (var __lifetime_0 = (own-literal ""))
            (var __lifetime_1 = (call str_compare (borrow пустая) (borrow __lifetime_0)))
            (destroy __lifetime_0)
            __lifetime_1)
          0)
        (block
          (= r (+ r 1))))
      (if (!= (call str_compare (borrow пустая) (borrow непустая)) 0) (block (= r (+ r 1))))
      (= знач r)
      (cleanup-exit (return знач) (destroy непустая) (destroy пустая)))))