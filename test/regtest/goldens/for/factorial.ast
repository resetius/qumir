(block
  (fun цикл () -> i64
    (block
      (var знач i64)
      (var ф i64)
      (var i i64)
      (= ф 0)
      (for i 1 1000 1 (block (= ф (call факториал 13))))
      (= знач ф)
      (return знач)))
  (fun факториал ((var число i64)) -> i64
    (block
      (var знач i64)
      (var i i64)
      (= знач 1)
      (for i 1 число 1 (block (= знач (* знач i))))
      (return знач))))