(block
  (fun <main> void () ()
    (block
      (var i i64)
      (var after i64)
      (= i 0)
      (= after 0)
      (loop
        nil
        nil
        (block
          (= i (+ i 1))
          (seq
            (call output_string "i=")
            (call output_int64 i 0)
            (call output_string "\n"))
          (cond (== i 3) (block (seq (call output_string "break") (call output_string "\n")) break))
          (= after (+ after 10)))
        nil
        (cast 1 bool))
      (seq
        (call output_string "loop ended i=")
        (call output_int64 i 0)
        (call output_string " after=")
        (call output_int64 after 0)
        (call output_string "\n")))))