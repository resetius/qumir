| disable_exec
использовать Комплексные числа

алг вещ real_part(компл z)
нач
    знач := Re(z)
кон

алг вещ imag_part(компл z)
нач
    знач := Im(z)
кон

алг компл make_complex(вещ re, вещ im)
нач
    знач := re + im*i
кон

алг компл add_twice(компл a, компл b)
нач
    знач := a + b + b
кон

алг
нач
    компл a, b

    a := make_complex(2.0, 5.0)
    вывод "arg Re=", real_part(a), " Im=", imag_part(a), нс

    b := add_twice(a, i)
    вывод "return Re=", Re(b), " Im=", Im(b), нс
кон
