использовать Комплексные числа

алг
нач
    компл a, b, c

    a := 1.0 + 2.0*i
    b := 3.0 + 4.0*i

    c := a + b
    вывод "add Re=", Re(c), " Im=", Im(c), нс

    c := b - a
    вывод "sub Re=", Re(c), " Im=", Im(c), нс

    c := a * b
    вывод "mul Re=", Re(c), " Im=", Im(c), нс

    c := b / a
    вывод "div Re=", Re(c), " Im=", Im(c), нс

    c := -a
    вывод "neg Re=", Re(c), " Im=", Im(c), нс
кон
