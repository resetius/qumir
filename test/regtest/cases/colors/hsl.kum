использовать Цвета

алг
нач
    цвет c
    цел r, g, b

    | H=0 s=100 l=50 -> красный
    c := HSL(0, 100, 50)
    разложить в RGB(c, r, g, b)
    вывод "hsl red: r=", r, " g=", g, " b=", b, нс

    | H=120 -> зелёный
    c := HSL(120, 100, 50)
    разложить в RGB(c, r, g, b)
    вывод "hsl green: r=", r, " g=", g, " b=", b, нс

    | H=240 -> синий
    c := HSL(240, 100, 50)
    разложить в RGB(c, r, g, b)
    вывод "hsl blue: r=", r, " g=", g, " b=", b, нс

    | l=0 -> чёрный независимо от h,s
    c := HSL(180, 100, 0)
    разложить в RGB(c, r, g, b)
    вывод "hsl black: r=", r, " g=", g, " b=", b, нс

    | l=100 -> белый независимо от h,s
    c := HSL(180, 100, 100)
    разложить в RGB(c, r, g, b)
    вывод "hsl white: r=", r, " g=", g, " b=", b, нс
