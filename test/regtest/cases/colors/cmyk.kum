использовать Цвета

алг
нач
    цвет c
    цел r, g, b

    | C=0 M=100 Y=100 K=0 -> красный
    c := CMYK(0, 100, 100, 0)
    разложить в RGB(c, r, g, b)
    вывод "cmyk red: r=", r, " g=", g, " b=", b, нс

    | C=100 M=0 Y=100 K=0 -> зелёный
    c := CMYK(100, 0, 100, 0)
    разложить в RGB(c, r, g, b)
    вывод "cmyk green: r=", r, " g=", g, " b=", b, нс

    | C=100 M=100 Y=0 K=0 -> синий
    c := CMYK(100, 100, 0, 0)
    разложить в RGB(c, r, g, b)
    вывод "cmyk blue: r=", r, " g=", g, " b=", b, нс

    | K=100 -> чёрный
    c := CMYK(0, 0, 0, 100)
    разложить в RGB(c, r, g, b)
    вывод "cmyk black: r=", r, " g=", g, " b=", b, нс

    | C=M=Y=K=0 -> белый
    c := CMYK(0, 0, 0, 0)
    разложить в RGB(c, r, g, b)
    вывод "cmyk white: r=", r, " g=", g, " b=", b, нс
кон
