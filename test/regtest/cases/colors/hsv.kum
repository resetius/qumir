использовать Цвета

алг
нач
    цвет c
    цел r, g, b

    | H=0 s=100 v=100 -> красный
    c := HSV(0, 100, 100)
    разложить в RGB(c, r, g, b)
    вывод "hsv red: r=", r, " g=", g, " b=", b, нс

    | H=120 -> зелёный
    c := HSV(120, 100, 100)
    разложить в RGB(c, r, g, b)
    вывод "hsv green: r=", r, " g=", g, " b=", b, нс

    | H=240 -> синий
    c := HSV(240, 100, 100)
    разложить в RGB(c, r, g, b)
    вывод "hsv blue: r=", r, " g=", g, " b=", b, нс

    | v=0 -> чёрный
    c := HSV(0, 100, 0)
    разложить в RGB(c, r, g, b)
    вывод "hsv black: r=", r, " g=", g, " b=", b, нс
