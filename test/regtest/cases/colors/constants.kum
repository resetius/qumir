использовать Цвета

алг
нач
    цвет c
    цел r, g, b

    c := чёрный
    разложить в RGB(c, r, g, b)
    вывод "black: r=", r, " g=", g, " b=", b, нс

    c := белый
    разложить в RGB(c, r, g, b)
    вывод "white: r=", r, " g=", g, " b=", b, нс

    c := красный
    разложить в RGB(c, r, g, b)
    вывод "red: r=", r, " g=", g, " b=", b, нс

    c := зелёный
    разложить в RGB(c, r, g, b)
    вывод "green: r=", r, " g=", g, " b=", b, нс

    c := синий
    разложить в RGB(c, r, g, b)
    вывод "blue: r=", r, " g=", g, " b=", b, нс

    c := серый
    разложить в RGB(c, r, g, b)
    вывод "gray: r=", r, " g=", g, " b=", b, нс

    c := прозрачный
    разложить в RGB(c, r, g, b)
    вывод "transparent: r=", r, " g=", g, " b=", b, нс
кон
