использовать Цвета

алг
нач
    цвет c
    цел r, g, b

    c := RGB(255, 128, 0)
    разложить в RGB(c, r, g, b)
    вывод "rgb: r=", r, " g=", g, " b=", b, нс

    | RGBA — alpha не влияет на RGB-компоненты
    c := RGBA(10, 20, 30, 128)
    разложить в RGB(c, r, g, b)
    вывод "rgba: r=", r, " g=", g, " b=", b, нс

    | Границы
    c := RGB(0, 0, 0)
    разложить в RGB(c, r, g, b)
    вывод "min: r=", r, " g=", g, " b=", b, нс

    c := RGB(255, 255, 255)
    разложить в RGB(c, r, g, b)
    вывод "max: r=", r, " g=", g, " b=", b, нс
кон
